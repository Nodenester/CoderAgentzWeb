@inherits LayoutComponentBase
@inject IHttpContextAccessor HttpContextAccessor

<div class="app-container">
    <header class="app-header">
        <div class="header-left">
            <a href="/" class="logo">CoderAgentz</a>
        </div>
        <div class="header-right">
            @if (HttpContextAccessor.HttpContext?.User?.Identity?.IsAuthenticated == true)
            {
                <span class="user-name">@HttpContextAccessor.HttpContext?.User?.Identity?.Name</span>
                <a href="/logout" class="btn btn-outline">Logout</a>
            }
            else
            {
                <a href="/login" class="btn btn-success">Login with GitHub</a>
            }
        </div>
    </header>

    <main class="app-main">
        @Body
    </main>

    <footer class="app-footer">
        <span>CoderAgentz - Autonomous AI Coding Agent</span>
    </footer>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">X</a>
</div>

<style>
    * {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
    }

    .app-container {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        background: #0d1117;
        color: #c9d1d9;
    }

    .app-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 2rem;
        background: #161b22;
        border-bottom: 1px solid #30363d;
    }

    .logo {
        font-size: 1.5rem;
        font-weight: bold;
        color: #58a6ff;
        text-decoration: none;
    }

    .logo:hover {
        color: #79c0ff;
    }

    .header-right {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .user-name {
        color: #8b949e;
    }

    .btn {
        padding: 0.5rem 1rem;
        border-radius: 6px;
        border: none;
        cursor: pointer;
        font-weight: 500;
        text-decoration: none;
        font-size: 0.9rem;
    }

    .btn-success {
        background: #238636;
        color: white;
    }

    .btn-success:hover {
        background: #2ea043;
    }

    .btn-outline {
        background: transparent;
        border: 1px solid #30363d;
        color: #c9d1d9;
    }

    .btn-outline:hover {
        background: #30363d;
    }

    .app-main {
        flex: 1;
        padding: 2rem;
    }

    .app-footer {
        padding: 1rem 2rem;
        background: #161b22;
        border-top: 1px solid #30363d;
        text-align: center;
        color: #8b949e;
        font-size: 0.8rem;
    }

    #blazor-error-ui {
        background: #f85149;
        color: white;
        padding: 0.5rem 1rem;
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        display: none;
        z-index: 1000;
    }

    #blazor-error-ui .reload, #blazor-error-ui .dismiss {
        color: white;
        margin-left: 1rem;
    }
</style>
